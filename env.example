
### Basic environment variables
# Service name (default: llm_service)
SERVICE_NAME=llm_service
# Environment (dev / prod, default: dev)
NODE_ENV=dev

### HTTP Config
# HTTP server port (default: 8010)
HTTP_PORT=8010
# Comma-separated IP allowlist (enforced in non-dev, default: empty)
IP_WHITELIST=127.0.0.1,10.0.0.1

### Redis Config
# Redis host (default: 127.0.0.1)
REDIS_HOST=127.0.0.1
# Redis port (default: 6379)
REDIS_PORT=6379
# Redis password (default: empty)
REDIS_PASSWORD=xxx
# TTL (seconds) for task results in Redis (default: 3600)
REDIS_TASK_RESULT_TTL=3600

### Vector Store Config
# Vector store backend (chroma / pg, default: chroma)
VECTOR_STORE=chroma

### Chroma Config
# Chroma host (default: 127.0.0.1)
CHROMA_HOST=127.0.0.1
# Chroma port (default: 8000)
CHROMA_PORT=8000
# Chroma tenant name (default: llm_tenant)
CHROMA_TENANT=llm_tenant
# Chroma database name (default: llm_db)
CHROMA_DATABASE=llm_db

### PostgreSQL Config
# PostgreSQL host (default: 127.0.0.1)
PG_HOST=127.0.0.1
# PostgreSQL port (default: 5432)
PG_PORT=5432
# PostgreSQL user (default: llm_user)
PG_USERNAME=llm_user
# PostgreSQL password (default: empty)
PG_PASSWORD=xxx
# PostgreSQL database name (default: llm_db)
PG_DATABASE=llm_db

### Manifest Config
# Manifest file path (default: empty)
MANIFEST_PATH=llm-manifest.json

### LLM Config
# LLM model (default: empty)
LLM_MODEL=xxx
# LLM API key (default: empty)
LLM_API_KEY=xxx
# LLM base URL (default: empty)
LLM_BASE_URL=xxx
# LLM timeout in milliseconds (default: 30000)
LLM_TIMEOUT=30000

### Extraction Model Config
# Extraction model (defaults to LLM_MODEL if unset)
EXTRACTION_MODEL=xxx
# Extraction model API key (defaults to LLM_API_KEY if unset)
EXTRACTION_MODEL_API_KEY=xxx
# Extraction model base URL (defaults to LLM_BASE_URL if unset)
EXTRACTION_MODEL_BASE_URL=http://localhost:8110/v1

### Embedding Model Config
# Embedding model (default: empty)
EMBEDDING_MODEL=xxx
# Embedding model API key (default: empty)
EMBEDDING_MODEL_API_KEY=xxx
# Embedding model base URL (default: empty)
EMBEDDING_MODEL_BASE_URL=xxx
# Embedding dimension (default: 1024)
EMBEDDING_DIMENSION=1024

### MCP Service Config
# MCP service endpoint URL (default: empty)
MCP_BASE_URL=http://localhost:8120/mcp
# MCP access token (optional, default: empty)
MCP_ACCESS_TOKEN=xxx
# MCP timeout in milliseconds (default: 30000)
MCP_TIMEOUT=30000

### Message List Config
# Comma-separated Redis list keys to listen on (default: empty)
MSG_LIST_LISTEN=llm:chat:REQUEST,llm:knowledge:REQUEST

### Chat Task Config
# Default temperature for chat generation (default: 0.4)
CHAT_TEMPERATURE=0.4
# Max number of history messages to keep (default: 20)
CHAT_HISTORY_MAX_LENGTH=20
# Number of knowledge items to retrieve (default: 5)
RAG_TOPK=5
# Distance threshold for knowledge items (default: 0.3)
RAG_DISTANCE_THRESHOLD=0.3
# Number of long-term memory items to retrieve (default: 5)
LTM_TOPK=5
# Distance threshold for long-term memory items (default: 0.3)
LTM_DISTANCE_THRESHOLD=0.3
# Max MCP tool-calling iterations per chat (default: 5)
MCP_MAX_ITERATIONS=5
# Distance threshold for merging similar long-term memory entries (default: 0.08)
LTM_MERGE_DISTANCE_THRESHOLD=0.08